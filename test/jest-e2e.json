{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "transform": { "^.+\\.(t|j)s$": "ts-jest" },
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/src/$1",
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "globalSetup": "<rootDir>/test/global-setup.ts",
  "setupFiles": ["<rootDir>/test/setup-env.ts"],
  "testTimeout": 30000,
  "forceExit": true,
  "maxWorkers": 1
}
